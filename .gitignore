# ================================================
# REPORTS - Keep visualizations, ignore text reports
# ================================================

# Ignore generated text reports (can be regenerated)
reports/*.txt
reports/*.log
reports/*.html
reports/*.pdf

# Keep JSON results for metrics demonstration
!reports/*.json

# Keep all images/plots for portfolio demonstration
!reports/*.png
!reports/*.jpg
!reports/*.jpeg
!reports/*.svg

# Keep CSV comparisons
!reports/*.csv

# Ignore plots subdirectory if exists
reports/plots/